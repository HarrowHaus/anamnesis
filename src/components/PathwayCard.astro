---
// §3.5 — Pathway card (sibling). A curated, ordered walk through entries.
import { plateUrl } from "../lib/plates";

interface Pathway {
  title: string;
  slug: string;
  one_line?: string;
  glyph?: string;
  stops?: unknown[];
}
interface Props {
  pathway: Pathway;
  href?: string;
}
const { pathway, href } = Astro.props;
const url = href ?? `/pathways/${pathway.slug}`;
const img = plateUrl(pathway.glyph);
const stops = pathway.stops?.length ?? 0;
---

<article class="path">
  <a class="path__link" href={url}>
    <div class="path__plate">
      {img
        ? <img class="u-plate" src={img} alt="" loading="lazy" />
        : <div class="u-plate-fallback" role="presentation"></div>}
    </div>
    <div class="path__body">
      <p class="u-eyebrow">Pathway{stops ? ` · ${stops} stops` : ""}</p>
      <h3 class="path__title">{pathway.title}</h3>
      {pathway.one_line && <p class="path__line">{pathway.one_line}</p>}
      <span class="path__cta">Walk this path →</span>
    </div>
  </a>
</article>

<style>
  .path {
    position: relative;
    border: var(--border-w) solid var(--color-border);
    border-radius: var(--radius-l);
    overflow: hidden;
    min-height: 220px;
    transition: transform var(--dur-fast) var(--ease-reveal),
      box-shadow var(--dur-fast) var(--ease-reveal);
  }
  .path:hover { transform: translateY(-2px); box-shadow: var(--shadow-card); }
  .path__link { display: block; color: inherit; text-decoration: none; height: 100%; }
  .path__plate { position: absolute; inset: 0; }
  .path__plate .u-plate { opacity: 0.5; }
  .path__body {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-m);
    background: linear-gradient(
      to top,
      var(--color-surface) 35%,
      color-mix(in srgb, var(--color-surface) 70%, transparent) 70%,
      transparent
    );
  }
  .path__title { font-size: var(--step-2); margin-bottom: var(--space-3xs); }
  .path__line { color: var(--color-text-muted); margin-bottom: var(--space-2xs); }
  .path__cta {
    font-family: var(--font-ui);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
  }
</style>
