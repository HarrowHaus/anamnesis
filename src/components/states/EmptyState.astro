---
// §3.15 — Empty / no-results. Never a dead end: suggest pathways.
interface Props {
  title?: string;
  message?: string;
  suggestions?: { label: string; href: string }[];
}
const {
  title = "Nothing here yet",
  message = "No entries match those filters. Try a guided pathway instead.",
  suggestions = [],
} = Astro.props;
---

<div class="empty">
  <p class="empty__mark" aria-hidden="true">⌕</p>
  <h2 class="empty__title">{title}</h2>
  <p class="empty__msg u-measure">{message}</p>
  {suggestions.length > 0 && (
    <ul class="empty__sugg" role="list">
      {suggestions.map((s) => <li><a href={s.href}>{s.label} →</a></li>)}
    </ul>
  )}
</div>

<style>
  .empty {
    text-align: center;
    padding: var(--space-2xl) var(--gutter);
    border: var(--border-w) dashed var(--color-border-strong);
    border-radius: var(--radius-l);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xs);
  }
  .empty__mark { font-size: var(--step-4); color: var(--color-border-strong); margin: 0; }
  .empty__title { font-size: var(--step-2); margin: 0; }
  .empty__msg { color: var(--color-text-muted); }
  .empty__sugg { display: flex; flex-wrap: wrap; justify-content: center; gap: var(--space-s); list-style: none; padding: 0; margin: var(--space-s) 0 0; }
  .empty__sugg a { font-family: var(--font-ui); text-decoration: none; }
  .empty__sugg a:hover { text-decoration: underline; }
</style>
