---
// §3.15 — 404. Drops the lost reader onto Start Here.
interface Props {
  ctaHref?: string;
  ctaLabel?: string;
}
const { ctaHref = "/start", ctaLabel = "Start Here →" } = Astro.props;
---

<div class="nf">
  <p class="nf__code" aria-hidden="true">404</p>
  <h2 class="nf__title">This page slipped the archive</h2>
  <p class="nf__msg u-measure">The thread you followed doesn't lead anywhere — yet. Begin where everyone begins.</p>
  <a class="nf__cta" href={ctaHref}>{ctaLabel}</a>
</div>

<style>
  .nf {
    text-align: center;
    padding: var(--space-2xl) var(--gutter);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2xs);
  }
  .nf__code {
    font-family: var(--font-display);
    font-size: var(--step-5);
    color: var(--color-border-strong);
    margin: 0;
    line-height: 1;
  }
  .nf__title { font-size: var(--step-2); margin: 0; }
  .nf__msg { color: var(--color-text-muted); }
  .nf__cta {
    margin-block-start: var(--space-s);
    font-family: var(--font-ui);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    font-size: var(--step--1);
    padding: 0.7em 1.2em;
    border: var(--border-w) solid var(--color-text);
    border-radius: var(--radius-m);
    text-decoration: none;
  }
  .nf__cta:hover { background: var(--color-accent); color: var(--color-accent-text); border-color: var(--color-accent); }
</style>
