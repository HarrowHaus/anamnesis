---
// §3.5 — Casebook card (sibling). A worked decode of an artifact.
import type { ImageMetadata } from "astro";
import { plateUrl, isSeedPlate } from "../lib/plates";

interface CaseEntry {
  title: string;
  slug: string;
  artifact: string;
  one_line?: string;
  plate?: ImageMetadata;
  glyph?: string;
  symbol_lineage?: string[];
}
interface Props {
  entry: CaseEntry;
  href?: string;
}
const { entry, href } = Astro.props;
const url = href ?? `/casebook/${entry.slug}`;
const img = plateUrl(entry.plate, entry.glyph);
const seed = isSeedPlate(entry.plate);
const count = entry.symbol_lineage?.length ?? 0;
---

<article class="case">
  <a class="case__link" href={url}>
    <div class="case__plate">
      {img
        ? <img class="u-plate" src={img} data-plate={seed ? "seed" : "real"} alt={`The ${entry.artifact}`} loading="lazy" />
        : <div class="u-plate-fallback" role="presentation"></div>}
      <span class="case__tag">Decode</span>
    </div>
    <div class="case__body">
      <p class="u-eyebrow">{entry.artifact}</p>
      <h3 class="case__title">{entry.title}</h3>
      {entry.one_line && <p class="case__line">{entry.one_line}</p>}
      {count > 0 && (
        <p class="case__lineage">{count} symbol{count === 1 ? "" : "s"} assembled</p>
      )}
    </div>
  </a>
</article>

<style>
  .case {
    background: var(--color-surface);
    border: var(--border-w) solid var(--color-border);
    border-radius: var(--radius-l);
    overflow: hidden;
    transition: transform var(--dur-fast) var(--ease-reveal),
      box-shadow var(--dur-fast) var(--ease-reveal);
  }
  .case:hover { transform: translateY(-2px); box-shadow: var(--shadow-card); }
  .case__link { display: block; color: inherit; text-decoration: none; }
  .case__plate { position: relative; aspect-ratio: 16 / 10; background: var(--color-surface-sunk); }
  .case__tag {
    position: absolute;
    inset-block-end: var(--space-2xs);
    inset-inline-start: var(--space-2xs);
    font-family: var(--font-ui);
    font-size: var(--step--1);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    padding: 0.2em 0.6em;
    background: var(--color-accent);
    color: var(--color-accent-text);
    border-radius: var(--radius-s);
  }
  .case__body { padding: var(--space-s); }
  .case__title { font-size: var(--step-1); margin-bottom: var(--space-3xs); }
  .case__line { color: var(--color-text-muted); margin-bottom: var(--space-2xs); }
  .case__lineage {
    font-family: var(--font-ui);
    font-size: var(--step--1);
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
